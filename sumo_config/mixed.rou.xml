    <vehicle id="bus_0" type="bus" route="urban_1" depart="10"/>
    <vehicle id="truck_0" type="truck" route="highway_1" depart="20"/>
    <vehicle id="car_2" type="car" route="highway_2" depart="30"/>

</routes>
