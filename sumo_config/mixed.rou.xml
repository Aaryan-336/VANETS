    <route id="urban_2" edges="ue3 ue4 ue5 te0 te1 he0 he1 he2"/>

    <!-- Highway Routes -->
    <route id="highway_1" edges="he0 he1 he2"/>
    <route id="highway_2" edges="he2 he1 he0"/>

    <!-- Vehicles -->
    <vehicle id="car_0" type="car" route="urban_1" depart="0"/>
