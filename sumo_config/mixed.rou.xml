    <vType id="bus" accel="1.0" decel="4.0" sigma="0.5" length="10" minGap="3" maxSpeed="11.1" color="1,0,0"/>
    <vType id="truck" accel="1.0" decel="4.0" sigma="0.5" length="12" minGap="3" maxSpeed="11.1" color="0,0,1"/>

    <!-- Urban Routes -->
